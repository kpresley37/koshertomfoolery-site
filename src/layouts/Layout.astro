---
const { title } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>

  <body>
    <header class="nav">
      <div class="logo">Kosher Tomfoolery</div>
      <nav>
        <a href="/">Home</a>
        <a href="/about">About</a>
      </nav>
    </header>

    <main>
      <slot />
    </main>

  </body>
</html>

<style>
  body {
  margin: 0;
  font-family: system-ui, sans-serif;
  background: radial-gradient(circle at 50% 0%, #1a1a2e, #0a0a0f 60%);
  color: white;
  overflow-x: hidden;
}
body::before {
  content: "";
  position: fixed;
  top: -200px;
  left: 50%;
  transform: translateX(-50%);
  width: 600px;
  height: 600px;
  background: radial-gradient(circle, rgba(139,92,246,0.15), transparent 70%);
  filter: blur(80px);
  animation: pulse 6s ease-in-out infinite alternate;
  z-index: -1;
}

@keyframes pulse {
  from { opacity: 0.4; }
  to { opacity: 0.8; }
}

  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 20px 40px;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(10px);
    position: sticky;
    top: 0;
  }

  .logo {
    font-weight: bold;
    font-size: 1.2rem;
    letter-spacing: 1px;
  }

  nav a {
    color: #aaa;
    text-decoration: none;
    margin-left: 20px;
    transition: 0.3s ease;
  }

  nav a:hover {
    color: #8b5cf6;
  }
</style>