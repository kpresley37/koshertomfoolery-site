    const parser = new XMLParser();
    const json = parser.parse(xml);

    const entries = json?.feed?.entry || [];
    latestVideos = Array.isArray(entries)
      ? entries.slice(0, 3)
      : [entries].slice(0, 3);
      console.log(JSON.stringify(latestVideos, null, 2));
  }
} catch (error) {
