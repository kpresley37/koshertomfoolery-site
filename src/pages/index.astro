  margin-top: 20px;
}

.video-grid iframe {
  width: 100%;
  aspect-ratio: 16 / 9;
  border-radius: 12px;
  border: none;
}

.card:nth-child(3) {
  border-color: rgba(255, 0, 80, 0.3);
}
</style>

<script is:inline src="https://cdn.jsdelivr.net/npm/particles.js@2.0.0/particles.min.js"></script>

<script is:inline>
document.addEventListener("DOMContentLoaded", function () {

  particlesJS("particles-js", {
    particles: {
      number: {
        value: 40,
        density: {
          enable: true,
          value_area: 1000
        }
      },

      color: {
        value: ["#c4b5fd", "#a78bfa", "#ffffff"]
      },

      shape: {
        type: "circle"
      },

      opacity: {
        value: 0.35,
        random: true
      },

      size: {
        value: 4,
        random: true
      },

      move: {
        enable: true,
        speed: 0.25,
        direction: "none",
        random: true,
        straight: false,
        out_mode: "out"
      },

      line_linked: {
        enable: false
      }
    },

    interactivity: {
      events: {
        onhover: { enable: false },
        onclick: { enable: false }
      }
    },

    retina_detect: true
  });

  /* Force animation loop */
  setTimeout(() => {
    if (window.pJSDom && window.pJSDom.length) {
      window.pJSDom[0].pJS.fn.particlesRefresh();
    }
  }, 100);

});
</script>

