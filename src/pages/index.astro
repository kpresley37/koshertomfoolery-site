---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Kosher Tomfoolery | Play Smart. Build Better.">

  <section class="hero">
    <h1>Kosher Tomfoolery</h1>
    <p class="tagline">Play Smart. Build Better.</p>
  </section>

</Layout>

<style>
.hero {
  text-align: center;
  padding: 140px 20px;
}

.hero h1 {
  font-size: 3rem;
  margin-bottom: 15px;
}

.tagline {
  font-size: 1.5rem;
  color: #8b5cf6;
  animation: glow 3s ease-in-out infinite alternate;
}

@keyframes glow {
  from {
    text-shadow: 0 0 5px #8b5cf6;
  }
  to {
    text-shadow: 0 0 20px #8b5cf6;
  }
}
</style>
