---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Kosher Tomfoolery | Play Smart. Build Better.">

  <section class="hero">
    <h1>Kosher Tomfoolery</h1>
    <p class="tagline">Play Smart. Build Better.</p>

    <div class="cta-group">
      <a href="#content" class="btn primary">Enter the Command Center</a>
      <a href="https://twitch.tv/YOURCHANNEL" target="_blank" class="btn secondary">
        Watch Live
      </a>
    </div>
  </section>

  <section id="content" class="content">
    <h2>Command Center</h2>
    <p class="section-sub">
      Live streams. Tactical breakdowns. Strategic plays.
    </p>

    <div class="video-section">
  <h3>YouTube</h3>

  <div class="video-grid">
    <iframe
      src="https://youtube.com/embed/r2rHQIG1U2U"
      frameborder="0"
      allowfullscreen>
    </iframe>

    <iframe
      src="https://www.youtube.com/embed/YOUR_VIDEO_ID_2"
      frameborder="0"
      allowfullscreen>
    </iframe>
  </div>
</div>

      <div class="card">
        <h3>Twitch</h3>
        <p>Live gameplay and real-time strategy.</p>
      </div>

      <div class="card">
        <h3>TikTok</h3>
        <p>Clips, chaos, and sharp highlights.</p>
      </div>
    </div>
  </section>

</Layout>

<style>
.hero {
  min-height: 90vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 40px 20px;
}

.tagline {
  font-size: 1.5rem;
  color: #8b5cf6;
  animation: glow 3s ease-in-out infinite alternate;
  margin-bottom: 40px;
}

.cta-group {
  display: flex;
  justify-content: center;
  gap: 20px;
  flex-wrap: wrap;
}

.btn {
  padding: 12px 24px;
  border-radius: 8px;
  text-decoration: none;
  font-weight: 600;
  transition: all 0.3s ease;
}

.primary {
  background: #8b5cf6;
  color: white;
}

.primary:hover {
  transform: translateY(-3px);
  box-shadow: 0 10px 25px rgba(139, 92, 246, 0.4);
}

.secondary {
  border: 2px solid #8b5cf6;
  color: #8b5cf6;
}

.secondary:hover {
  background: #8b5cf6;
  color: white;
  transform: translateY(-3px);
}

@keyframes glow {
  from { text-shadow: 0 0 5px #8b5cf6; }
  to { text-shadow: 0 0 20px #8b5cf6; }
}

.content {
  padding: 100px 20px;
  text-align: center;
}

.content h2 {
  font-size: 2.2rem;
  margin-bottom: 10px;
}

.section-sub {
  color: #aaa;
  margin-bottom: 60px;
}

.cards {
  display: flex;
  justify-content: center;
  gap: 30px;
  flex-wrap: wrap;
}

.card {
  background: rgba(255, 255, 255, 0.03);
  border: 1px solid rgba(139, 92, 246, 0.2);
  padding: 30px;
  border-radius: 12px;
  width: 260px;
  transition: all 0.3s ease;
}

.card:hover {
  transform: translateY(-8px);
  border-color: #8b5cf6;
  box-shadow: 0 20px 40px rgba(139, 92, 246, 0.2);
}

.card h3 {
  margin-bottom: 10px;
}

.video-section {
  width: 100%;
}

.video-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  gap: 20px;
  margin-top: 20px;
}

.video-grid iframe {
  width: 100%;
  aspect-ratio: 16 / 9;
  border-radius: 12px;
  border: none;
}
</style>