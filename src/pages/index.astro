---
import Layout from "../layouts/Layout.astro";
---

<Layout title="Kosher Tomfoolery | Calculated Chaos.">

<section class="hero">

  <div id="particles-js"></div>

  <h1>KosherTomfoolery</h1>
  <p class="tagline">Calculated Chaos</p>

  <p class="brand-description">
    KosherTomfoolery is a gaming channel built on calculated chaos,
    ridiculous decisions, and the occasional moment of accidental brilliance.
  </p>

  <div id="live-banner" style="display:none;">
    🔴 KosherTomfoolery is LIVE on Twitch!
    <a href="https://twitch.tv/koshertomfoolery" target="_blank">Watch Now</a>
  </div>

  <section class="featured-video">
    <h2>Featured Video</h2>

    <div class="video-container">
      <iframe
        src="https://www.youtube.com/embed/ogrp0UARWaE"
        title="KosherTomfoolery Featured Video"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
        allowfullscreen>
      </iframe>
    </div>
  </section>

  <div class="cta-group">
    <a href="#content" class="btn primary">Enter the Command Center</a>
    <a href="https://twitch.tv/koshertomfoolery" target="_blank" class="btn secondary">
      Watch Live
    </a>
  </div>

</section>

<section class="featured">

  <h2>Kosher Certified Tomfoolery</h2>
  <p class="section-sub">
    A perfectly executed moment of calculated chaos.
  </p>

  <div class="video-section">
    <h3>YouTube</h3>
    <div class="video-grid" id="youtube-videos"></div>
  </div>

  <div class="video-section">
    <h3>Live on Twitch</h3>

    <div class="twitch-container">
      
      <iframe
        src="https://player.twitch.tv/?channel=koshertomfoolery&parent=koshertomfoolery.com&parent=www.koshertomfoolery.com"
        height="480"
        width="100%"
        allowfullscreen>
    </iframe>
    </div>
  </div>

  <div class="card">
    <h3>TikTok</h3>
    <p>Clips, personality, and behind-the-scenes moments.</p>

    <a
      href="https://www.tiktok.com/@koshertomfoolery"
      target="_blank"
      rel="noopener noreferrer"
      class="card-link">
      Visit TikTok →
    </a>
  </div>

</section>

<footer class="footer">
  <a href="https://www.youtube.com/@KosherTomfoolery" target="_blank">YouTube</a>
  <a href="https://www.twitch.tv/koshertomfoolery" target="_blank">Twitch</a>
  <a href="https://www.tiktok.com/@koshertomfoolery" target="_blank">TikTok</a>
</footer>

</Layout>

<script is:inline>

async function loadVideos() {

  const container = document.getElementById("youtube-videos");

  if (!container) return;

  const response = await fetch("/api/youtube");
  const videos = await response.json();

  container.innerHTML = "";

  videos.forEach(video => {

    const iframe = document.createElement("iframe");

    iframe.src = `https://www.youtube.com/embed/${video.videoId}`;
    iframe.allowFullscreen = true;

    container.appendChild(iframe);

  });

}

window.addEventListener("load", loadVideos);

</script>

<script is:inline>

async function checkLive(){

  const res = await fetch("/api/twitch");
  const data = await res.json();

  if(data.live){
    document.getElementById("live-banner").style.display = "block";
  }

}

checkLive();

</script>

<style>

.hero {
  min-height: 90vh;
  display:flex;
  flex-direction:column;
  justify-content:center;
  align-items:center;
  text-align:center;
  padding:40px 20px;
  position:relative;
}

.brand-description {
  max-width:620px;
  margin-top:18px;
  margin-bottom:35px;
  font-size:1.1rem;
  color:#bbb;
  line-height:1.6;
}

.tagline {
  font-size:1.5rem;
  color:#8b5cf6;
}

.video-container iframe {
  width:100%;
  aspect-ratio:16/9;
  border-radius:12px;
  border:none;
}

.video-grid {
  display:grid;
  grid-template-columns:repeat(auto-fit, minmax(280px,1fr));
  gap:20px;
  margin-top:20px;
}

.video-grid iframe {
  width:100%;
  aspect-ratio:16/9;
  border:none;
  border-radius:12px;
}

.twitch-container iframe {
  border:none;
  border-radius:12px;
}

.cta-group {
  display:flex;
  justify-content:center;
  gap:20px;
  flex-wrap:wrap;
}

.btn {
  padding:12px 24px;
  border-radius:8px;
  text-decoration:none;
  font-weight:600;
}

.primary {
  background:#8b5cf6;
  color:white;
}

.secondary {
  border:2px solid #8b5cf6;
  color:#8b5cf6;
}

.footer {
  display:flex;
  justify-content:center;
  gap:30px;
  padding:40px;
  border-top:1px solid rgba(255,255,255,0.1);
}

</style>