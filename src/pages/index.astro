<script type="module">
import { tsParticles } from "https://cdn.jsdelivr.net/npm/tsparticles-engine@2/+esm";

tsParticles.load("particles", {
  background: {
    color: "transparent"
  },
  fpsLimit: 60,
  particles: {
    number: {
      value: 60,
      density: {
        enable: true,
        area: 800
      }
    },
    color: {
      value: "#8b5cf6"
    },
    shape: {
      type: "circle"
    },
    opacity: {
      value: { min: 0.1, max: 0.4 }
    },
    size: {
      value: { min: 1, max: 3 }
    },
    move: {
      enable: true,
      speed: 0.3,
      direction: "none",
      random: true,
      outModes: {
        default: "out"
      }
    }
  },
  interactivity: {
    events: {
      onHover: {
        enable: true,
        mode: "repulse"
      }
    },
    modes: {
      repulse: {
        distance: 80
      }
    }
  }
});
</script>


<style>

