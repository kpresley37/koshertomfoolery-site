}
---

<Layout title="Kosher Tomfoolery | Play Smart. Build Better.">

  <section class="hero">
    <h1>Kosher Tomfoolery</h1>
    <p class="tagline">Play Smart. Build Better.</p>

    <div class="cta-group">
      <a href="#content" class="btn primary">Enter the Command Center</a>
      <a href="https://twitch.tv/YOURCHANNEL" target="_blank" class="btn secondary">
        Watch Live
      </a>
    </div>
  </section>

  <div class="video-section">
  <h3>YouTube</h3>
  <div class="video-grid" id="youtube-videos"></div>
</div>

<script>
  async function loadVideos() {
    try {
      const response = await fetch("/api/youtube");
      const videos = await response.json();

      const container = document.getElementById("youtube-videos");

      videos.forEach(video => {
        if (!video.videoId) return;

        const iframe = document.createElement("iframe");
        iframe.src = `https://www.youtube.com/embed/${video.videoId}`;
        iframe.width = "560";
        iframe.height = "315";
        iframe.allowFullscreen = true;

        container.appendChild(iframe);
      });
    } catch (err) {
      console.error("Failed to load YouTube videos:", err);
    }
  }

  loadVideos();
</script>


      <div class="video-section">
  <h3>Live on Twitch</h3>

  <div class="twitch-container">
    <iframe
      src="https://player.twitch.tv/?channel=koshertomfoolery&parent=koshertomfoolery-site.vercel.app"
      height="480"
      width="100%"
      allowfullscreen>
    </iframe>
  </div>
</div>
  </section>

</Layout>

<style>
.hero {
  min-height: 90vh;
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  text-align: center;
  padding: 40px 20px;
}

.twitch-container iframe {
